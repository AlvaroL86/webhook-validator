# Variables de entorno para WhatsApp Webhook Validator

# Puerto en el que correrá la aplicación
PORT=5000

# Token de verificación de Meta (debe coincidir con el configurado en Meta Dashboard)
VERIFY_TOKEN=MiTokenSecreto123!@#

# Entorno (development o production)
FLASK_ENV=production

# Base de Datos PostgreSQL (opcional, para guardar mensajes)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=whatsapp_db
DB_PORT=5432

# n8n Integration (opcional, para disparar workflows)
N8N_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/whatsapp

# Slack Integration (opcional, para notificaciones)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
